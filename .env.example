# ==============================================================================
#  ORDER PAYMENT API — Environment Configuration Template
# ==============================================================================
#
#  USAGE
#    cp .env.example .env
#    Fill in all required (★) values before starting the application.
#
#  SECURITY
#    • Never commit .env to version control.
#    • Rotate secrets immediately if accidentally exposed.
#    • Use a secrets manager (e.g. AWS Secrets Manager, Vault) in production.
#
#  LEGEND
#    ★ Required — application will not boot without this value
#    ◎ Optional — has a safe default; override only when needed
#
# ==============================================================================


# ------------------------------------------------------------------------------
#  RAILS CORE
# ------------------------------------------------------------------------------

# ★ Decrypts config/credentials.yml.enc at boot.
#   Source: cat config/master.key
#   Never share or commit this value.
RAILS_MASTER_KEY=

# ◎ Runtime environment. Controls config/environments/<env>.rb loading.
#   Allowed: development | test | production
RAILS_ENV=development

# ◎ Puma thread pool size AND Active Record connection pool size.
#   Recommended: match your expected concurrency level.
#   Rule of thumb: CPU-bound apps → 1–3; IO-bound apps → 5–10.
RAILS_MAX_THREADS=5

# ◎ Log verbosity.
#   Allowed: debug | info | warn | error | fatal | unknown
RAILS_LOG_LEVEL=debug

# ◎ TCP port Puma binds to.
PORT=3000

# ◎ Set to "true" to run Solid Queue supervisor inside the Puma process.
#   Suitable for single-server deployments. Leave unset on multi-worker setups.
#   Allowed: true | <unset>
SOLID_QUEUE_IN_PUMA=


# ------------------------------------------------------------------------------
#  DATABASE — PostgreSQL
# ------------------------------------------------------------------------------

# ◎ Hostname or IP of the PostgreSQL server.
#   Docker: use the service name (e.g. "db").
#   Local:  use "localhost".
DB_HOST=localhost

# ◎ PostgreSQL port. Default: 5432.
DB_PORT=5432

# ◎ PostgreSQL role used to authenticate.
DB_USERNAME=postgres

# ★ Password for the above PostgreSQL role.
DB_PASSWORD=


# ------------------------------------------------------------------------------
#  BACKGROUND JOBS — Solid Queue
# ------------------------------------------------------------------------------

# ◎ Number of concurrent worker processes for Solid Queue.
#   Increase for high-throughput job workloads.
JOB_CONCURRENCY=1


# ------------------------------------------------------------------------------
#  AUTHENTICATION — JWT
# ------------------------------------------------------------------------------

# ★ HMAC secret used to sign and verify JWT tokens.
#   Must be cryptographically random and at least 64 characters.
#   Generate: rails secret
JWT_SECRET_KEY=

# ◎ Token expiry in seconds. Default: 86400 (24 hours).
#   Shorter values improve security; longer values improve UX.
JWT_EXPIRATION_SECONDS=86400


# ------------------------------------------------------------------------------
#  PAYMENT GATEWAY — Midtrans
# ------------------------------------------------------------------------------
#  Sandbox dashboard : https://dashboard.sandbox.midtrans.com/settings/config_info
#  Production dashboard: https://dashboard.midtrans.com/settings/config_info

# ★ Server Key — used for backend-to-Midtrans API calls. Keep strictly secret.
MIDTRANS_SERVER_KEY=

# ★ Client Key — safe to expose to clients; used for Snap.js / frontend SDKs.
MIDTRANS_CLIENT_KEY=

# ◎ Target Midtrans environment.
#   Allowed: sandbox | production
#   WARNING: Never point production keys at the sandbox environment.
MIDTRANS_ENVIRONMENT=sandbox
